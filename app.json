{
  "expo": {
    "name": "Controlar+",
    "slug": "controlarapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "controlarapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splashscreen_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "newArchEnabled": true,
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDisplayName": "Controlar+",
        "NSFaceIDUsageDescription": "Usamos Face ID para proteger seu acesso ao app",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.gustavodev25.controlarapp"
    },
    "android": {
      "newArchEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "package": "com.gustavodev25.controlarapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Usamos Face ID para proteger seu acesso ao app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splashscreen_logo.png",
          "backgroundColor": "#000000",
          "dark": {
            "image": "./assets/images/splashscreen_logo.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5090aaec-94b6-440c-b5dd-c839eb3abb4d"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/5090aaec-94b6-440c-b5dd-c839eb3abb4d"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}