{
  "name": "controlarapp",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev": "concurrently -n server,expo -c blue,green --kill-others \"npm run server:dev\" \"expo start\"",
    "dev:android": "concurrently -n server,expo -c blue,green --kill-others \"npm run server:dev\" \"expo start --android\"",
    "dev:ios": "concurrently -n server,expo -c blue,green --kill-others \"npm run server:dev\" \"expo start --ios\"",
    "dev:web": "concurrently -n server,expo -c blue,green --kill-others \"npm run server:dev\" \"expo start --web\"",
    "perf:collect": "powershell -ExecutionPolicy Bypass -File scripts/perf/collect-metrics.ps1",
    "perf:scenario": "powershell -ExecutionPolicy Bypass -File scripts/perf/run-scenario.ps1",
    "perf:parse-framestats": "npx tsx scripts/perf/parse-framestats.ts",
    "perf:summarize": "npx tsx scripts/perf/summarize.ts",
    "perf:check-assets": "npx tsx scripts/perf/check-asset-budgets.ts",
    "server": "cd server && node index.js",
    "server:dev": "cd server && npm run dev",
    "server:install": "cd server && npm install",
    "reset-project": "node ./scripts/reset-project.js",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:apk": "eas build --profile development-apk --platform android",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo-google-fonts/ar-one-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.10",
    "expo-gl": "~16.0.10",
    "expo-glass-effect": "~0.1.8",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sensors": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.7.0",
    "lottie-react-native": "^7.3.5",
    "lucide-react-native": "^0.562.0",
    "moti": "^0.30.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-base64": "^0.2.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "^0.5.1",
    "three": "^0.182.0",
    "victory-native": "^36.9.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "private": true
}
