# Pluggy API Credentials
# Obtenha suas credenciais em https://dashboard.pluggy.ai
PLUGGY_CLIENT_ID=seu_client_id_aqui
PLUGGY_CLIENT_SECRET=seu_client_secret_aqui
# Use true para ambiente sandbox (teste) e false para producao
PLUGGY_SANDBOX=true

# Server Configuration
PORT=3001

# Firebase Admin (opcional - para sincronizacao direta)
# FIREBASE_PROJECT_ID=seu_project_id
# FIREBASE_PRIVATE_KEY=sua_private_key
# FIREBASE_CLIENT_EMAIL=seu_client_email

# Stripe (Assinaturas via Apple Pay)
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx

# Apple IAP
APPLE_SHARED_SECRET=
APPLE_BUNDLE_ID=com.gustavodev25.controlarapp

# App Store Server API. Permite revalidar uma assinatura Apple salva pelo
# originalTransactionId, mesmo quando o dispositivo atual usa outro Apple ID.
APPLE_IAP_KEY_ID=
APPLE_IAP_ISSUER_ID=
APPLE_IAP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_SERVER_API_ENVIRONMENT=production
