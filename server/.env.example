# Pluggy API Credentials
# Obtenha suas credenciais em https://dashboard.pluggy.ai
PLUGGY_CLIENT_ID=seu_client_id_aqui
PLUGGY_CLIENT_SECRET=seu_client_secret_aqui
# Use true para ambiente sandbox (teste) e false para producao
PLUGGY_SANDBOX=true

# Server Configuration
PORT=3001
ADMIN_API_TOKEN=troque_por_um_token_forte

# Firebase Admin (obrigatorio para IAP, assinaturas e rotas autenticadas)
# Informe o JSON completo da conta de servico em texto ou base64.
FIREBASE_SERVICE_ACCOUNT=
# Alternativa ao FIREBASE_SERVICE_ACCOUNT:
# FIREBASE_PROJECT_ID=seu_project_id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# FIREBASE_CLIENT_EMAIL=seu_client_email

# Stripe (Assinaturas via Apple Pay)
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx

# Apple IAP
APPLE_SHARED_SECRET=
APPLE_BUNDLE_ID=com.gustavodev25.controlarapp

# App Store Server API. Permite revalidar uma assinatura Apple salva pelo
# originalTransactionId, mesmo quando o dispositivo atual usa outro Apple ID.
APPLE_IAP_KEY_ID=
APPLE_IAP_ISSUER_ID=
APPLE_IAP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_SERVER_API_ENVIRONMENT=production

# Google Play Billing
# Informe o JSON completo da conta de servico em texto ou base64.
GOOGLE_PLAY_SERVICE_ACCOUNT=
GOOGLE_PLAY_PACKAGE_NAME=com.gustavodev25.controlarapp
GOOGLE_PLAY_PRO_PRODUCT_ID=controlarapp_pro_monthly
GOOGLE_PLAY_TRIAL_OFFER_ID=trial-7d

# Token secreto incluido na URL de push do Pub/Sub:
# https://SEU_BACKEND/api/google/rtdn?token=SEU_TOKEN
GOOGLE_PLAY_RTDN_TOKEN=
